# Chexit API — default production host is https://chexit.onrender.com (see src/api/chexit.ts).
# Override only if you deploy a different API: VITE_CHEXIT_API_URL=https://your-api.example (no /predict).
# Local: leave EMPTY — npm run dev proxies /api/predict → http://127.0.0.1:8000.
# VITE_CHEXIT_API_URL=
# VITE_USE_RELATIVE_API=

# Set to 1 to run `npm run test:integration` (Firestore scratch doc; add rules for __vitest_connectivity).
VITE_RUN_FIREBASE_INTEGRATION=

# Firebase (optional – app uses fallbacks if unset)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Chexit API (Render / local uvicorn) — U-Net from Google Drive via gdown if files missing ---
# CHEXIT_SKIP_GDOWN=1
# CHEXIT_GDOWN_UNET_BEST_ID=
# CHEXIT_GDOWN_ALL_UNET=1
# CHEXIT_GDOWN_UNET_WEIGHTS_ID=
# CHEXIT_GDOWN_UNET_FINAL_ID=
# CHEXIT_ASSETS_ROOT=
