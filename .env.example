# Chexit API — Vercel / public site: REQUIRED. Full https:// URL of your deployed FastAPI (no /predict).
# Your browser cannot reach http://127.0.0.1:8000 on your PC from vercel.app — deploy API (see render.yaml) first.
# On the API host set CHEXIT_CORS_ORIGINS=https://your-app.vercel.app (comma-list if multiple).
# Local: leave EMPTY — npm run dev proxies /api/predict → 127.0.0.1:8000.
# VITE_CHEXIT_API_URL=
# VITE_USE_RELATIVE_API=

# Set to 1 to run `npm run test:integration` (Firestore scratch doc; add rules for __vitest_connectivity).
VITE_RUN_FIREBASE_INTEGRATION=

# Firebase (optional – app uses fallbacks if unset)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
