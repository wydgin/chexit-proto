# Chexit API — production: full https URL of your deployed API.
# Local dev: leave EMPTY so Vite proxies /api → http://127.0.0.1:8000 (works with HTTPS preview / Cursor).
# Only set http://127.0.0.1:8000 if you open the app over http:// (not https://).
# VITE_CHEXIT_API_URL=

# Set to 1 to run `npm run test:integration` (Firestore scratch doc; add rules for __vitest_connectivity).
VITE_RUN_FIREBASE_INTEGRATION=

# Firebase (optional – app uses fallbacks if unset)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
